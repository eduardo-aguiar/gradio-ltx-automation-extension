{
  "manifest_version": 3,
  "name": "Gradio LTX Speech Runner",
  "description": "Runs speech/audio variants on a Gradio LTX audio-to-video interface, downloads each generated MP4, then continues.",
  "version": "0.2.0",
  "permissions": ["downloads", "storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Gradio LTX Speech Runner",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
